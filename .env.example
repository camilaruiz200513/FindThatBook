# This file documents the environment variables the project understands.
# Copy to .env.local and fill in your own values. .env.local is gitignored.
#
# NOTE: Vite auto-loads VITE_* variables from .env.local (frontend). The .NET
# backend does NOT auto-load this file — it only reads real process env vars,
# appsettings.json, and user secrets. For the backend, either export the
# variable in your shell before "dotnet run" or use:
#   dotnet user-secrets set "Gemini:ApiKey" "<your-key>"  (preferred in dev)

# ------- Gemini (required for LLM extraction, optional for fallback mode) -------
# Docs:   https://ai.google.dev/gemini-api/docs/api-key
# Create: https://aistudio.google.com/app/apikey  (keys start with "AIzaSy…")
# ASP.NET Core maps the double-underscore form to the Gemini:ApiKey config section.
Gemini__ApiKey=

# ------- Frontend → Backend wiring -------
# Override if the backend is not running on http://localhost:5186
VITE_API_URL=http://localhost:5186

# Copy to .env.local and fill in your own values. .env.local is gitignored.

# ------- Gemini (required for LLM extraction) -------
# Get a free key at https://aistudio.google.com/app/apikey
# In development you can also set this via .NET user secrets:
#   cd backend/src/FindThatBook.Api
#   dotnet user-secrets set "Gemini:ApiKey" "<your-key>"
GEMINI_API_KEY=

# ------- Frontend → Backend wiring -------
# Override if the backend is not running on http://localhost:5186
VITE_API_URL=http://localhost:5186
